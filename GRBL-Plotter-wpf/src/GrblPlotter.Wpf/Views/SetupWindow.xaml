<Window x:Class="GrblPlotter.Wpf.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GrblPlotter.Wpf.Converters"
        Title="Setup"
        Height="560" Width="520"
        Icon="/Assets/Icon.ico"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <conv:HexToBrushConverter x:Key="HexToBrush"/>
  </Window.Resources>
  <DockPanel Margin="8">
    <TextBlock DockPanel.Dock="Top" Text="Setup" Style="{StaticResource PanelHeader}" FontSize="16" Margin="4,0,0,8"/>

    <Border DockPanel.Dock="Bottom" Style="{StaticResource PanelBorder}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Reset defaults" Command="{Binding ResetDefaultsCommand}" Style="{StaticResource GhostButton}"/>
          <Button Content="Reload" Command="{Binding ReloadFromDiskCommand}" Style="{StaticResource GhostButton}"/>
          <Button Content="Save" Command="{Binding SaveCommand}"/>
          <Button Content="Close" Click="Close_Click" Style="{StaticResource GhostButton}"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
      </DockPanel>
    </Border>

    <TabControl Margin="0,0,0,8">
      <!-- Connection defaults -->
      <TabItem Header="Connection">
        <StackPanel Margin="8">
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="Last port" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Settings.Connection.LastPort}"/>
            <TextBlock Grid.Row="1" Text="Last baud rate" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding BaudRates}" Text="{Binding Settings.Connection.LastBaud}" IsEditable="True"/>
            <TextBlock Grid.Row="2" Text="Poll interval (ms)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Connection.PollIntervalMs}"/>
            <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Auto-connect on startup" IsChecked="{Binding Settings.Connection.AutoConnectOnStartup}"/>
            <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Send soft-reset ($X clear) right after connect" IsChecked="{Binding Settings.Connection.SendSoftResetOnConnect}"/>
          </Grid>
        </StackPanel>
      </TabItem>

      <!-- Streaming -->
      <TabItem Header="Streaming">
        <StackPanel Margin="8">
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="Planner buffer slots" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Settings.Streaming.PlannerBufferSlots}"/>
            <TextBlock Grid.Row="1" Text="Send pump interval (ms)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.Streaming.SendIntervalMs}"/>
            <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Run $C check-mode pass before streaming" IsChecked="{Binding Settings.Streaming.UseCheckModeBeforeRun}"/>
            <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Pause on tool-change (M6)" IsChecked="{Binding Settings.Streaming.PauseOnToolChangeM6}"/>
          </Grid>
        </StackPanel>
      </TabItem>

      <!-- 2D view colors -->
      <TabItem Header="2D view">
        <StackPanel Margin="8">
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>

            <TextBlock Text="Background" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Settings.Colors.BackgroundColor}"/>
            <Border Grid.Column="2" Width="18" Height="18" BorderBrush="{StaticResource BorderBrushKey}" BorderThickness="1" Background="{Binding Settings.Colors.BackgroundColor, Converter={StaticResource HexToBrush}}"/>

            <TextBlock Grid.Row="1" Text="Toolpath (cut)" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.Colors.ToolpathColor}"/>
            <Border Grid.Row="1" Grid.Column="2" Width="18" Height="18" BorderBrush="{StaticResource BorderBrushKey}" BorderThickness="1" Background="{Binding Settings.Colors.ToolpathColor, Converter={StaticResource HexToBrush}}"/>

            <TextBlock Grid.Row="2" Text="Rapid moves" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Colors.RapidColor}"/>
            <Border Grid.Row="2" Grid.Column="2" Width="18" Height="18" BorderBrush="{StaticResource BorderBrushKey}" BorderThickness="1" Background="{Binding Settings.Colors.RapidColor, Converter={StaticResource HexToBrush}}"/>

            <TextBlock Grid.Row="3" Text="Grid" VerticalAlignment="Center"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.Colors.GridColor}"/>
            <Border Grid.Row="3" Grid.Column="2" Width="18" Height="18" BorderBrush="{StaticResource BorderBrushKey}" BorderThickness="1" Background="{Binding Settings.Colors.GridColor, Converter={StaticResource HexToBrush}}"/>

            <TextBlock Grid.Row="4" Text="Tool position" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Settings.Colors.ToolPositionColor}"/>
            <Border Grid.Row="4" Grid.Column="2" Width="18" Height="18" BorderBrush="{StaticResource BorderBrushKey}" BorderThickness="1" Background="{Binding Settings.Colors.ToolPositionColor, Converter={StaticResource HexToBrush}}"/>
          </Grid>
          <CheckBox Content="Show grid" IsChecked="{Binding Settings.Colors.ShowGrid}" Margin="0,6,0,0"/>
          <CheckBox Content="Show rapid moves" IsChecked="{Binding Settings.Colors.ShowRapidMoves}"/>
        </StackPanel>
      </TabItem>

      <!-- Device defaults -->
      <TabItem Header="Devices">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="8">
            <TextBlock Text="Active device" Style="{StaticResource PanelHeader}"/>
            <ComboBox ItemsSource="{Binding DeviceOptions}" SelectedItem="{Binding Settings.Devices.ActiveDevice}" Margin="0,0,0,8"/>

            <TextBlock Text="Laser defaults" Style="{StaticResource PanelHeader}"/>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
              <TextBlock Text="Power" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding Settings.Devices.Laser.Power}"/>
              <TextBlock Grid.Row="1" Text="Speed" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.Devices.Laser.Speed}"/>
              <TextBlock Grid.Row="2" Text="Passes" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Devices.Laser.Passes}"/>
              <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Air assist" IsChecked="{Binding Settings.Devices.Laser.AirAssist}"/>
            </Grid>

            <TextBlock Text="Plotter defaults" Style="{StaticResource PanelHeader}"/>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
              <TextBlock Text="Z up" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding Settings.Devices.Plotter.ZUp}"/>
              <TextBlock Grid.Row="1" Text="Z down" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.Devices.Plotter.ZDown}"/>
              <TextBlock Grid.Row="2" Text="Speed" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Devices.Plotter.Speed}"/>
            </Grid>

            <TextBlock Text="Router defaults" Style="{StaticResource PanelHeader}"/>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
              <TextBlock Text="Feed XY" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding Settings.Devices.Router.SpeedXy}"/>
              <TextBlock Grid.Row="1" Text="Feed Z" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.Devices.Router.SpeedZ}"/>
              <TextBlock Grid.Row="2" Text="Depth" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Devices.Router.Depth}"/>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Axes / machine area -->
      <TabItem Header="Axes">
        <StackPanel Margin="8">
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="Axis count (3–6)" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Settings.AxisCount}"/>
            <TextBlock Grid.Row="1" Text="Rotary axis name" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding RotaryAxes}"
                      SelectedItem="{Binding Settings.RotaryAxisName}"/>
            <TextBlock Grid.Row="2" Text="Machine min X/Y" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
              <TextBox Width="80" Text="{Binding Settings.MachineMinX}" Margin="0,0,4,0"/>
              <TextBox Width="80" Text="{Binding Settings.MachineMinY}"/>
            </StackPanel>
            <TextBlock Grid.Row="3" Text="Machine max X/Y" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
              <TextBox Width="80" Text="{Binding Settings.MachineMaxX}" Margin="0,0,4,0"/>
              <TextBox Width="80" Text="{Binding Settings.MachineMaxY}"/>
            </StackPanel>
            <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Show machine limits overlay" IsChecked="{Binding Settings.ShowMachineLimits}"/>
            <CheckBox Grid.Row="5" Grid.ColumnSpan="2" Content="Use fixed machine area for view" IsChecked="{Binding Settings.ShowFixedMachineArea}"/>
          </Grid>
          <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"
                     Text="Axis count 4/5/6 enables A / B / C DRO, zero and jog on the main panel."/>
        </StackPanel>
      </TabItem>

      <!-- Import graphic -->
      <TabItem Header="Import">
        <StackPanel Margin="8">
          <CheckBox Content="Auto hatch fill on import" IsChecked="{Binding Settings.ImportHatchFill}"/>
          <Grid Margin="0,6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Text="Hatch spacing" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Settings.ImportHatchSpacing}"/>
            <TextBlock Grid.Row="1" Text="Hatch angle °" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.ImportHatchAngle}"/>
            <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Apply tangential axis on import" IsChecked="{Binding Settings.ImportTangential}" Margin="0,6,0,0"/>
          </Grid>
          <Grid Margin="0,4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Tangential offset °" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Settings.ImportTangentialAngle}"/>
          </Grid>
        </StackPanel>
      </TabItem>

      <!-- Custom 1–16 -->
      <TabItem Header="Custom 1–16">
        <DockPanel Margin="8">
          <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"
                     Text="Edit labels and G-code scripts for the 16 main-panel buttons."/>
          <DataGrid ItemsSource="{Binding Settings.CustomButtons}" AutoGenerateColumns="False"
                    CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                    AlternatingRowBackground="{StaticResource SurfaceAltBrush}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="90"/>
              <DataGridTextColumn Header="Code / script" Binding="{Binding Code}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </TabItem>

      <!-- Hotkeys help -->
      <TabItem Header="Hotkeys">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="8">
            <TextBlock Text="Keyboard shortcuts" Style="{StaticResource PanelHeader}"/>
            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="12">
              <Run Text="Ctrl+O"/><Run Text="  Open G-Code file" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Ctrl+S"/><Run Text="  Save G-Code file" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Space"/><Run Text="   Feed hold" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Ctrl+R"/><Run Text="  Soft reset" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Esc"/><Run Text="     Jog cancel" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Arrow keys"/><Run Text="  Jog X/Y" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="PgUp / PgDn"/><Run Text="  Jog Z" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Shift+drag"/><Run Text="  Pan 2D view" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="Wheel"/><Run Text="     Zoom 2D view" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="F5"/><Run Text="      Start streaming" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="F6"/><Run Text="      Pause stream" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
              <Run Text="F7"/><Run Text="      Stop streaming" Foreground="{StaticResource TextMutedBrush}"/><LineBreak/>
            </TextBlock>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
