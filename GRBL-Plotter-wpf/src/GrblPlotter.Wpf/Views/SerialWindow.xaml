<Window x:Class="GrblPlotter.Wpf.Views.SerialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COM CNC"
        Height="520" Width="420"
        Icon="/Assets/Icon.ico"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="8">
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}"/>
      <ComboBox Grid.Column="1" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaud}" Margin="6,0"/>
      <Button Grid.Column="2" Content="{Binding IsConnected, Converter={StaticResource ConnLabel}}" Command="{Binding ConnectToggleCommand}" MinWidth="64" Margin="4,0"/>
      <Button Grid.Column="3" Content="Scan" Command="{Binding RefreshPortsCommand}" Style="{StaticResource GhostButton}"/>
    </Grid>

    <Border DockPanel.Dock="Top" Style="{StaticResource PanelBorder}" Margin="0,0,0,8">
      <StackPanel>
        <TextBlock Text="Real-time Status Report" Style="{StaticResource PanelHeader}"/>
        <TextBlock Text="{Binding MachineStateText, StringFormat=Status {0}}"/>
        <TextBlock FontFamily="Consolas" Text="{Binding WorkX, StringFormat=WPos X:{0}}"/>
        <TextBlock FontFamily="Consolas" Text="{Binding WorkY, StringFormat=WPos Y:{0}}"/>
        <TextBlock FontFamily="Consolas" Text="{Binding WorkZ, StringFormat=WPos Z:{0}}"/>
        <TextBlock FontFamily="Consolas" Foreground="{StaticResource TextMutedBrush}"
                   Text="{Binding MachineX, StringFormat=MPos X:{0}}"/>
      </StackPanel>
    </Border>

    <UniformGrid DockPanel.Dock="Bottom" Columns="5" Margin="0,8,0,0">
      <Button Content="Clear" Click="Clear_Click" Style="{StaticResource GhostButton}"/>
      <Button Content="$" Command="{Binding SendManualCommand}" CommandParameter="$$" Style="{StaticResource GhostButton}"/>
      <Button Content="$I" Command="{Binding SendManualCommand}" CommandParameter="$I" Style="{StaticResource GhostButton}"/>
      <Button Content="RES" Command="{Binding SoftResetCommand}" Style="{StaticResource DangerButton}"/>
      <Button Content="RS" Command="{Binding KillAlarmCommand}" Style="{StaticResource GhostButton}"/>
    </UniformGrid>

    <DockPanel>
      <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="CmdBox" KeyDown="CmdBox_KeyDown"/>
        <Button Grid.Column="1" Content="Send" Margin="6,0,0,0" Click="Send_Click"/>
      </Grid>
      <ListBox ItemsSource="{Binding LogLines}" FontFamily="Consolas" FontSize="11"
               Background="{StaticResource BgDeepBrush}" Foreground="{StaticResource TextBrush}"
               BorderBrush="{StaticResource BorderBrushKey}"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
    </DockPanel>
  </DockPanel>
</Window>
