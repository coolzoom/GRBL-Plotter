<Window x:Class="GrblPlotter.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About GRBL-Plotter"
        Height="420" Width="420"
        Icon="/Assets/Icon.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
      <Image Source="/Assets/modell.png" Width="140" Margin="0,0,0,10"/>
      <TextBlock Text="GRBL-Plotter WPF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock x:Name="VersionText" HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom">
      <TextBlock Text="© the GRBL-Plotter project contributors" HorizontalAlignment="Center" Margin="0,10,0,4" Foreground="{StaticResource TextMutedBrush}"/>
      <Button Content="Close" Click="Close_Click" HorizontalAlignment="Center" Width="110"/>
    </StackPanel>

    <StackPanel VerticalAlignment="Center">
      <TextBlock TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,14"
                 Text="An open source G-Code sender for GRBL based CNC machines, laser cutters and pen plotters — industrial dark theme WPF build."/>
      <TextBlock HorizontalAlignment="Center">
        <Hyperlink NavigateUri="https://grbl-plotter.de" RequestNavigate="Hyperlink_RequestNavigate">
          grbl-plotter.de
        </Hyperlink>
      </TextBlock>
    </StackPanel>
  </DockPanel>
</Window>
