<Window x:Class="GrblPlotter.Wpf.Views.CameraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GrblPlotter.Wpf.Converters"
        Title="Camera"
        Height="560" Width="640"
        Icon="/Assets/Icon.ico"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <conv:NullToVisibilityConverter x:Key="NullToVis"/>
  </Window.Resources>
  <DockPanel Margin="8">
    <TextBlock DockPanel.Dock="Top" Text="Camera / Teach Offset" Style="{StaticResource PanelHeader}" FontSize="15" Margin="4,0,0,8"/>

    <Border DockPanel.Dock="Bottom" Style="{StaticResource PanelBorder}">
      <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
    </Border>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="220"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="2">
        <Grid Background="{StaticResource BgDeepBrush}">
          <Image Source="{Binding StillImage}" Stretch="Uniform"/>
          <TextBlock Text="No frame — start camera or load still image."
                     Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" TextWrapping="Wrap"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"
                     Visibility="{Binding StillImage, Converter={StaticResource NullToVis}}"/>
          <!-- crosshair overlay -->
          <Rectangle Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                     Fill="{StaticResource AccentBrush}" Opacity="0.85" IsHitTestVisible="False"/>
          <Rectangle Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                     Fill="{StaticResource AccentBrush}" Opacity="0.85" IsHitTestVisible="False"/>
          <Ellipse Width="18" Height="18" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4"
                   HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Camera" Style="{StaticResource PanelHeader}"/>
              <ComboBox ItemsSource="{Binding Devices}" SelectedIndex="{Binding SelectedDeviceIndex}" Margin="0,0,0,4"/>
              <Button Content="Refresh devices" Command="{Binding RefreshDevicesCommand}" Style="{StaticResource GhostButton}"/>
              <Button Content="{Binding IsRunning, Converter={StaticResource ConnLabel}}" Command="{Binding ToggleCameraCommand}" Margin="0,4,0,0"/>
              <Button Content="Load still image…" Command="{Binding LoadStillImageCommand}" Style="{StaticResource GhostButton}" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Teach offset" Style="{StaticResource PanelHeader}"/>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="X" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding OffsetX}"/>
                <TextBlock Grid.Row="1" Text="Y" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OffsetY}"/>
              </Grid>
              <Button Content="Teach from current WPos" Command="{Binding TeachOffsetCommand}" Margin="0,6,0,0" Style="{StaticResource GhostButton}"/>
              <Button Content="Apply as G54 (G10)" Command="{Binding ApplyOffsetAsG54Command}" Margin="0,4,0,0" Style="{StaticResource GhostButton}"/>
              <Button Content="Send jog to offset" Command="{Binding SendJogToOffsetCommand}" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
