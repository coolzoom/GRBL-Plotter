<Window x:Class="GrblPlotter.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GrblPlotter.Wpf.ViewModels"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="{Binding WindowTitle}"
        Height="820" Width="1280"
        MinHeight="640" MinWidth="1024"
        Icon="/Assets/Icon.ico"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        Loaded="Window_Loaded">
  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>
  <DockPanel>
    <Menu DockPanel.Dock="Top" Name="MainMenu">
      <MenuItem Header="_File">
        <MenuItem Header="Open…" Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
        <MenuItem Header="Open Recent" Name="RecentMenu" SubmenuOpened="RecentMenu_SubmenuOpened"/>
        <MenuItem Header="Save…" Command="{Binding SaveFileCommand}" InputGestureText="Ctrl+S"/>
        <MenuItem Header="Clear workspace" Command="{Binding ClearWorkspaceCommand}"/>
        <MenuItem Header="Undo" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
        <Separator/>
        <MenuItem Header="Setup…" Click="OpenSetup_Click"/>
        <MenuItem Header="Export settings…" Command="{Binding ExportSettingsCommand}"/>
        <MenuItem Header="Import settings…" Command="{Binding ImportSettingsCommand}"/>
        <MenuItem Header="About…" Click="OpenAbout_Click"/>
        <Separator/>
        <MenuItem Header="Exit" Click="Exit_Click"/>
      </MenuItem>
      <MenuItem Header="_G-Code Creation">
        <MenuItem Header="Import any (SVG/DXF/HPGL/Gerber/Image/CSV)…" Command="{Binding OpenFileCommand}"/>
        <Separator/>
        <MenuItem Header="Text…" Click="OpenText_Click"/>
        <MenuItem Header="Shape…" Click="OpenShape_Click"/>
        <MenuItem Header="Image engraving…" Click="OpenImage_Click"/>
        <MenuItem Header="Barcode…" Click="OpenBarcode_Click"/>
        <MenuItem Header="Wire cutter…" Click="OpenWire_Click"/>
        <MenuItem Header="Jog path / Frame…" Click="OpenJogPath_Click"/>
        <MenuItem Header="Graphic tablet…" Click="OpenTablet_Click"/>
        <MenuItem Header="Hershey stroke text…" Click="OpenHershey_Click"/>
        <MenuItem Header="LFF font text…" Click="OpenLff_Click"/>
        <MenuItem Header="Hatch fill…" Command="{Binding ApplyHatchCommand}"/>
        <MenuItem Header="Apply tangential axis" Command="{Binding ApplyTangentialCommand}"/>
        <MenuItem Header="Extensions" Name="ExtensionsMenu" SubmenuOpened="ExtensionsMenu_SubmenuOpened"/>
      </MenuItem>
      <MenuItem Header="_G-Code Transform">
        <MenuItem Header="Mirror X" Command="{Binding TransformMirrorXCommand}"/>
        <MenuItem Header="Mirror Y" Command="{Binding TransformMirrorYCommand}"/>
        <MenuItem Header="Mirror Rotary" Command="{Binding TransformMirrorRotaryCommand}"/>
        <Separator/>
        <MenuItem Header="Rotate 90° CW" Command="{Binding TransformRotate90CwCommand}"/>
        <MenuItem Header="Rotate 90° CCW" Command="{Binding TransformRotate90CcwCommand}"/>
        <MenuItem Header="Rotate 180°" Command="{Binding TransformRotate180Command}"/>
        <MenuItem Header="Rotate (panel °)" Command="{Binding ApplyRotateTransformCommand}"/>
        <Separator/>
        <MenuItem Header="Use origin 0;0" IsCheckable="True" IsChecked="{Binding UseAbsoluteOrigin}"/>
        <MenuItem Header="Scale (panel factor)" Command="{Binding ApplyScaleTransformCommand}"/>
        <MenuItem Header="Scale X/Y independent" Command="{Binding TransformScaleXyIndepCommand}"/>
        <MenuItem Header="Scale to width" Command="{Binding TransformScaleToWidthCommand}"/>
        <MenuItem Header="Scale to height" Command="{Binding TransformScaleToHeightCommand}"/>
        <MenuItem Header="Scale X → rotary °" Command="{Binding TransformScaleToRotaryCommand}"/>
        <MenuItem Header="Scale Y → rotary °" Command="{Binding TransformScaleYToRotaryCommand}"/>
        <MenuItem Header="Radius compensation" Command="{Binding TransformRadiusCompCommand}"/>
        <MenuItem Header="Translate" Command="{Binding ApplyTranslateTransformCommand}"/>
        <MenuItem Header="Apply last transform" Command="{Binding ApplyLastTransformCommand}"/>
        <Separator/>
        <MenuItem Header="Origin → Center" Command="{Binding TransformOriginCenterCommand}"/>
        <MenuItem Header="Origin → Min XY" Command="{Binding TransformOriginMinCommand}"/>
        <MenuItem Header="Reverse paths" Command="{Binding TransformReverseCommand}"/>
        <Separator/>
        <MenuItem Header="Replace G2/G3 by lines" Command="{Binding TransformArcsToLinesCommand}"/>
        <MenuItem Header="Convert to polar" Command="{Binding TransformToPolarCommand}"/>
        <MenuItem Header="Convert Z → S spindle" Command="{Binding TransformZToSpindleCommand}"/>
        <MenuItem Header="Remove any Z move" Command="{Binding TransformRemoveZCommand}"/>
        <Separator/>
        <MenuItem Header="Reparse editor" Command="{Binding ApplyEditorCommand}"/>
      </MenuItem>
      <MenuItem Header="_Workpiece">
        <MenuItem Header="Home ($H)" Command="{Binding HomeMachineCommand}"/>
        <MenuItem Header="Zero XYZ" Command="{Binding ZeroXyzCommand}"/>
        <MenuItem Header="Zero XY" Command="{Binding ZeroXyCommand}"/>
        <MenuItem Header="Zero A" Command="{Binding ZeroACommand}" Visibility="{Binding AxisAVisibility}"/>
        <MenuItem Header="Zero B" Command="{Binding ZeroBCommand}" Visibility="{Binding AxisBVisibility}"/>
        <MenuItem Header="Zero C" Command="{Binding ZeroCCommand}" Visibility="{Binding AxisCVisibility}"/>
        <Separator/>
        <MenuItem Header="Coordinate systems…" Click="OpenCoord_Click"/>
        <MenuItem Header="G54" Command="{Binding SelectCoordCommand}" CommandParameter="G54"/>
        <MenuItem Header="G55" Command="{Binding SelectCoordCommand}" CommandParameter="G55"/>
        <MenuItem Header="G56" Command="{Binding SelectCoordCommand}" CommandParameter="G56"/>
        <MenuItem Header="G57" Command="{Binding SelectCoordCommand}" CommandParameter="G57"/>
        <MenuItem Header="G58" Command="{Binding SelectCoordCommand}" CommandParameter="G58"/>
        <MenuItem Header="G59" Command="{Binding SelectCoordCommand}" CommandParameter="G59"/>
        <Separator/>
        <MenuItem Header="Probing…" Click="OpenProbing_Click"/>
        <MenuItem Header="Height map…" Click="OpenHeightMap_Click"/>
        <MenuItem Header="Jog path creator…" Click="OpenJogPath_Click"/>
      </MenuItem>
      <MenuItem Header="_Machine">
        <MenuItem Header="COM CNC…" Click="OpenSerial_Click"/>
        <MenuItem Header="2nd Serial…" Click="OpenSecondSerial_Click"/>
        <MenuItem Header="DIY Control Pad…" Click="OpenDiyPad_Click"/>
        <MenuItem Header="3rd Serial…" Click="OpenThirdSerial_Click"/>
        <MenuItem Header="Refresh ports" Command="{Binding RefreshPortsCommand}"/>
        <Separator/>
        <MenuItem Header="GRBL Setup ($$)…" Click="OpenGrblSetup_Click"/>
        <MenuItem Header="Laser tools…" Click="OpenLaserTools_Click"/>
        <MenuItem Header="Camera…" Click="OpenCamera_Click"/>
        <MenuItem Header="Projector…" Click="OpenProjector_Click"/>
        <MenuItem Header="Process automation…" Click="OpenAutomation_Click"/>
        <Separator/>
        <MenuItem Header="Start streaming at line…" Command="{Binding StreamStartFromLineCommand}"/>
        <MenuItem Header="Soft RESET" Command="{Binding SoftResetCommand}"/>
        <MenuItem Header="Kill Alarm $X" Command="{Binding KillAlarmCommand}"/>
        <MenuItem Header="Feed Hold" Command="{Binding FeedHoldCommand}"/>
        <MenuItem Header="Cycle Start" Command="{Binding CycleStartCommand}"/>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Show toolpath" IsCheckable="True" IsChecked="{Binding ShowToolpath}"/>
        <MenuItem Header="Show pen-up / rapid" IsCheckable="True" IsChecked="{Binding ShowRapidMoves}"/>
        <MenuItem Header="Show dimensions" IsCheckable="True" IsChecked="{Binding ShowDimensionOverlay}"/>
        <MenuItem Header="Show ruler" IsCheckable="True" IsChecked="{Binding ShowRuler}"/>
        <MenuItem Header="Show info HUD" IsCheckable="True" IsChecked="{Binding ShowInfoHud}"/>
        <MenuItem Header="Show machine limits" IsCheckable="True" IsChecked="{Binding ShowMachineLimits}"/>
        <MenuItem Header="Show fixed machine area" IsCheckable="True" IsChecked="{Binding ShowFixedMachineArea}"/>
        <MenuItem Header="Show tool table overlay" IsCheckable="True" IsChecked="{Binding ShowToolTableOverlay}"/>
        <Separator/>
        <MenuItem Header="Reset zoom" Command="{Binding ResetZoomCommand}"/>
        <MenuItem Header="Bring forms to front" Click="BringFormsToFront_Click"/>
        <Separator/>
        <MenuItem Header="{DynamicResource Str.Language}">
          <MenuItem Header="English" Click="LangEn_Click"/>
          <MenuItem Header="中文" Click="LangZh_Click"/>
          <MenuItem Header="Deutsch" Click="LangDe_Click"/>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_Simulation">
        <MenuItem Header="Start" Command="{Binding SimStartCommand}"/>
        <MenuItem Header="Pause" Command="{Binding SimPauseCommand}"/>
        <MenuItem Header="Resume" Command="{Binding SimResumeCommand}"/>
        <MenuItem Header="Stop" Command="{Binding SimStopCommand}"/>
        <Separator/>
        <MenuItem Header="Speed ×2" Command="{Binding SimFasterCommand}"/>
        <MenuItem Header="Speed ÷2" Command="{Binding SimSlowerCommand}"/>
        <Separator/>
        <MenuItem Header="Enable GamePad" IsCheckable="True" Click="GamePadToggle_Click"/>
      </MenuItem>
    </Menu>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <Border Style="{StaticResource StatusBanner}" MinWidth="220">
          <TextBlock Text="{Binding ConnectionText}"/>
        </Border>
      </StatusBarItem>
      <StatusBarItem>
        <Border Style="{StaticResource StatusBanner}" MinWidth="280">
          <TextBlock Text="{Binding StatusBanner}"/>
        </Border>
      </StatusBarItem>
      <StatusBarItem HorizontalAlignment="Right">
        <TextBlock Text="{Binding MachineStateText, StringFormat=State: {0}}" Foreground="{StaticResource TextMutedBrush}"/>
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="240"/>
        <ColumnDefinition Width="*" MinWidth="360"/>
        <ColumnDefinition Width="300" MinWidth="260"/>
      </Grid.ColumnDefinitions>

      <!-- LEFT -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <!-- Streaming -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="G-Code Streaming" Style="{StaticResource PanelHeader}"/>
              <TextBlock Text="{Binding StreamInfo}" Foreground="{StaticResource TextMutedBrush}"/>
              <ProgressBar Height="10" Margin="0,4" Minimum="0" Maximum="100" Value="{Binding StreamProgress}"/>
              <UniformGrid Columns="3">
                <Button Content="Start" Command="{Binding StreamStartCommand}" IsEnabled="{Binding IsConnected}"/>
                <Button Content="Check" Command="{Binding StreamCheckCommand}" Style="{StaticResource GhostButton}" IsEnabled="{Binding IsConnected}"/>
                <Button Content="Stop" Command="{Binding StreamStopCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <Button Content="Start at line…" Command="{Binding StreamStartFromLineCommand}" Style="{StaticResource GhostButton}"
                      IsEnabled="{Binding IsConnected}" Margin="0,4,0,0"/>
              <UniformGrid Columns="2">
                <Button Content="Pause / Hold" Command="{Binding StreamPauseCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Resume" Command="{Binding StreamResumeCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="Simulation" Margin="0,8,0,2" Foreground="{StaticResource TextMutedBrush}"/>
              <UniformGrid Columns="4">
                <Button Content="Sim" Command="{Binding SimStartCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="❚❚" Command="{Binding SimPauseCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="▶" Command="{Binding SimResumeCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="■" Command="{Binding SimStopCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="{Binding FileLabel}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding DimensionText, StringFormat=Dim {0}}" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </Border>

          <!-- Flow -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Flow Control" Style="{StaticResource PanelHeader}"/>
              <UniformGrid Columns="2">
                <Button Content="Feed Hold" Command="{Binding FeedHoldCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Resume" Command="{Binding CycleStartCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Kill Alarm" Command="{Binding KillAlarmCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Door" Command="{Binding DoorCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <Button Content="RESET" Command="{Binding SoftResetCommand}" Style="{StaticResource DangerButton}" Height="36" FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <!-- Overrides -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Overrides" Style="{StaticResource PanelHeader}"/>
              <TextBlock Text="{Binding OvFeed, StringFormat=Feed {0}%}" />
              <UniformGrid Columns="5">
                <Button Content="−10" Command="{Binding OvFeedMinusCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="−1" Command="{Binding OvFeedMinusFineCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="100%" Command="{Binding OvFeedResetCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="+1" Command="{Binding OvFeedPlusFineCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="+10" Command="{Binding OvFeedPlusCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="{Binding OvRapid, StringFormat=Rapid {0}%}" Margin="0,6,0,0"/>
              <UniformGrid Columns="3">
                <Button Content="25%" Command="{Binding OvRapid25Command}" Style="{StaticResource GhostButton}"/>
                <Button Content="50%" Command="{Binding OvRapid50Command}" Style="{StaticResource GhostButton}"/>
                <Button Content="100%" Command="{Binding OvRapid100Command}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="{Binding OvSpindle, StringFormat=Spindle {0}%}" Margin="0,6,0,0"/>
              <UniformGrid Columns="5">
                <Button Content="−10" Command="{Binding OvSpindleMinusCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="−1" Command="{Binding OvSpindleMinusFineCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="100%" Command="{Binding OvSpindleResetCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="+1" Command="{Binding OvSpindlePlusFineCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="+10" Command="{Binding OvSpindlePlusCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <UniformGrid Columns="4" Margin="0,6,0,0">
                <Button Content="M3" Command="{Binding SpindleCwCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="M5" Command="{Binding SpindleStopCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="M7" Command="{Binding CoolantMistCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="M8" Command="{Binding CoolantFloodCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <Button Content="Coolant OFF M9" Command="{Binding CoolantOffCommand}" Style="{StaticResource GhostButton}" Margin="0,4,0,0"/>
              <TextBlock Text="Digital outs" Margin="0,6,0,2" Foreground="{StaticResource TextMutedBrush}"/>
              <UniformGrid Columns="4">
                <Button Content="D0+" Command="{Binding DigitalOutOnCommand}" CommandParameter="0" Style="{StaticResource GhostButton}"/>
                <Button Content="D1+" Command="{Binding DigitalOutOnCommand}" CommandParameter="1" Style="{StaticResource GhostButton}"/>
                <Button Content="D2+" Command="{Binding DigitalOutOnCommand}" CommandParameter="2" Style="{StaticResource GhostButton}"/>
                <Button Content="D3+" Command="{Binding DigitalOutOnCommand}" CommandParameter="3" Style="{StaticResource GhostButton}"/>
                <Button Content="D0−" Command="{Binding DigitalOutOffCommand}" CommandParameter="0" Style="{StaticResource GhostButton}"/>
                <Button Content="D1−" Command="{Binding DigitalOutOffCommand}" CommandParameter="1" Style="{StaticResource GhostButton}"/>
                <Button Content="D2−" Command="{Binding DigitalOutOffCommand}" CommandParameter="2" Style="{StaticResource GhostButton}"/>
                <Button Content="D3−" Command="{Binding DigitalOutOffCommand}" CommandParameter="3" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Origin -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Set G-Code Origin XY" Style="{StaticResource PanelHeader}"/>
              <UniformGrid Columns="3">
                <Button Content="TL" Command="{Binding SetOriginCornerCommand}" CommandParameter="TopLeft" Style="{StaticResource GhostButton}"/>
                <Button Content="TC" Command="{Binding SetOriginCornerCommand}" CommandParameter="TopCenter" Style="{StaticResource GhostButton}"/>
                <Button Content="TR" Command="{Binding SetOriginCornerCommand}" CommandParameter="TopRight" Style="{StaticResource GhostButton}"/>
                <Button Content="ML" Command="{Binding SetOriginCornerCommand}" CommandParameter="MidLeft" Style="{StaticResource GhostButton}"/>
                <Button Content="C" Command="{Binding SetOriginCornerCommand}" CommandParameter="Center" Style="{StaticResource GhostButton}"/>
                <Button Content="MR" Command="{Binding SetOriginCornerCommand}" CommandParameter="MidRight" Style="{StaticResource GhostButton}"/>
                <Button Content="BL" Command="{Binding SetOriginCornerCommand}" CommandParameter="BotLeft" Style="{StaticResource GhostButton}"/>
                <Button Content="BC" Command="{Binding SetOriginCornerCommand}" CommandParameter="BotCenter" Style="{StaticResource GhostButton}"/>
                <Button Content="BR" Command="{Binding SetOriginCornerCommand}" CommandParameter="BotRight" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Transform -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Transform" Style="{StaticResource PanelHeader}"/>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="Scale" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding TransformScale}"/>
                <TextBlock Grid.Row="1" Text="Rot°" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TransformRotate}"/>
                <TextBlock Grid.Row="2" Text="dX" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TransformDx}"/>
                <TextBlock Grid.Row="3" Text="dY" VerticalAlignment="Center"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TransformDy}"/>
              </Grid>
              <CheckBox Content="Use origin 0;0" IsChecked="{Binding UseAbsoluteOrigin}" Margin="0,4,0,0"/>
              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="Sx" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding TransformScaleX}"/>
                <TextBlock Grid.Row="1" Text="Sy" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TransformScaleY}"/>
                <TextBlock Grid.Row="2" Text="Ørot" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RotaryDiameter}"/>
                <TextBlock Grid.Row="3" Text="Rcomp" VerticalAlignment="Center"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RadiusComp}"/>
              </Grid>
              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="W→" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding TransformTargetWidth}"/>
                <Button Grid.Column="2" Content="W" Command="{Binding TransformScaleToWidthCommand}" Style="{StaticResource GhostButton}" Margin="4,0,0,0" MinWidth="32"/>
                <TextBlock Grid.Row="1" Text="H→" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TransformTargetHeight}"/>
                <Button Grid.Row="1" Grid.Column="2" Content="H" Command="{Binding TransformScaleToHeightCommand}" Style="{StaticResource GhostButton}" Margin="4,0,0,0" MinWidth="32"/>
              </Grid>
              <UniformGrid Columns="3" Margin="0,4,0,0">
                <Button Content="Scale" Command="{Binding ApplyScaleTransformCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Rotate" Command="{Binding ApplyRotateTransformCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Move" Command="{Binding ApplyTranslateTransformCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Mir X" Command="{Binding TransformMirrorXCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Mir Y" Command="{Binding TransformMirrorYCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Mir Rot" Command="{Binding TransformMirrorRotaryCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Y→°" Command="{Binding TransformScaleYToRotaryCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Rcomp" Command="{Binding TransformRadiusCompCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Rev" Command="{Binding TransformReverseCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Custom buttons 1–16 -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Custom 1–16" Style="{StaticResource PanelHeader}"/>
              <ItemsControl ItemsSource="{Binding CustomButtons}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="4" Rows="4"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding Label}" Command="{Binding DataContext.RunCustomCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Margin="1" FontSize="11"
                            ToolTip="{Binding Code}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Editor (AvalonEdit) -->
          <Border Style="{StaticResource PanelBorder}" MinHeight="220">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Text="G-Code" Style="{StaticResource PanelHeader}"/>
              <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                <UniformGrid Columns="2">
                  <Button Content="Apply / Reparse" Command="{Binding ApplyEditorCommand}"/>
                  <Button Content="Update 2D view" Command="{Binding ApplyEditorCommand}" Style="{StaticResource GhostButton}"/>
                </UniformGrid>
                <UniformGrid Columns="4" Margin="0,2,0,0">
                  <Button Content="Fold1" Click="FoldLevel1_Click" Style="{StaticResource GhostButton}" FontSize="10"/>
                  <Button Content="Fold2" Click="FoldLevel2_Click" Style="{StaticResource GhostButton}" FontSize="10"/>
                  <Button Content="Fold3" Click="FoldLevel3_Click" Style="{StaticResource GhostButton}" FontSize="10"/>
                  <Button Content="Expand" Click="FoldExpand_Click" Style="{StaticResource GhostButton}" FontSize="10"/>
                </UniformGrid>
              </StackPanel>
              <avalonedit:TextEditor x:Name="CodeEditor"
                                     FontFamily="Consolas" FontSize="11"
                                     ShowLineNumbers="True"
                                     WordWrap="False"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{StaticResource BgDeepBrush}"
                                     Foreground="{StaticResource TextBrush}">
                <avalonedit:TextEditor.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Send marked / current line" Click="SendEditorLine_Click"/>
                    <MenuItem Header="Find / Replace…" Click="FindReplace_Click"/>
                    <MenuItem Header="Insert PenUp" Command="{Binding InsertPenUpCommand}"/>
                    <MenuItem Header="Insert PenDown" Command="{Binding InsertPenDownCommand}"/>
                    <MenuItem Header="Comment unknown G/M" Command="{Binding CommentUnknownGCodeCommand}"/>
                    <Separator/>
                    <MenuItem Header="Sort blocks by Id" Command="{Binding SortBlocksByCommand}" CommandParameter="Id"/>
                    <MenuItem Header="Sort by Color" Command="{Binding SortBlocksByCommand}" CommandParameter="Color"/>
                    <MenuItem Header="Sort by Layer" Command="{Binding SortBlocksByCommand}" CommandParameter="Layer"/>
                    <MenuItem Header="Sort by Type" Command="{Binding SortBlocksByCommand}" CommandParameter="Type"/>
                    <MenuItem Header="Sort by Geometry" Command="{Binding SortBlocksByCommand}" CommandParameter="Geometry"/>
                    <MenuItem Header="Sort by Tool" Command="{Binding SortBlocksByCommand}" CommandParameter="Tool"/>
                    <MenuItem Header="Sort by Size" Command="{Binding SortBlocksByCommand}" CommandParameter="Size"/>
                    <MenuItem Header="Sort by Area" Command="{Binding SortBlocksByCommand}" CommandParameter="Area"/>
                    <MenuItem Header="Sort by Distance" Command="{Binding SortBlocksByCommand}" CommandParameter="Distance"/>
                    <Separator/>
                    <MenuItem Header="Remove Group tags" Command="{Binding RemoveXmlTagsCommand}" CommandParameter="group"/>
                    <MenuItem Header="Remove all XML tags" Command="{Binding RemoveXmlTagsCommand}" CommandParameter="all"/>
                    <Separator/>
                    <MenuItem Header="Fold 1st level" Click="FoldLevel1_Click"/>
                    <MenuItem Header="Fold 2nd level" Click="FoldLevel2_Click"/>
                    <MenuItem Header="Fold 3rd level" Click="FoldLevel3_Click"/>
                    <MenuItem Header="Expand all" Click="FoldExpand_Click"/>
                    <Separator/>
                    <MenuItem Header="Apply / Reparse" Command="{Binding ApplyEditorCommand}"/>
                  </ContextMenu>
                </avalonedit:TextEditor.ContextMenu>
              </avalonedit:TextEditor>
            </DockPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- CENTER -->
      <Grid Grid.Column="1" Margin="4,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DRO -->
        <Border Style="{StaticResource PanelBorder}" Grid.Row="0">
          <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <Button Content="Home" Command="{Binding HomeMachineCommand}" Width="72"/>
              <Button Content="Zero XY" Command="{Binding ZeroXyCommand}" Style="{StaticResource GhostButton}"/>
              <Button Content="Zero XYZ" Command="{Binding ZeroXyzCommand}" Style="{StaticResource GhostButton}"/>
            </StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/>
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="X" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WorkX}" Style="{StaticResource DroValue}"/>
              <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding WorkY}" Style="{StaticResource DroValue}"/>
              <TextBlock Grid.Row="0" Grid.Column="4" Text="Z" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding WorkZ}" Style="{StaticResource DroValue}"/>
              <TextBlock Grid.Row="0" Grid.Column="6" Text="A" VerticalAlignment="Center" FontWeight="Bold" Visibility="{Binding AxisAVisibility}"/>
              <TextBlock Grid.Row="0" Grid.Column="7" Text="{Binding WorkA}" Style="{StaticResource DroValue}" Visibility="{Binding AxisAVisibility}"/>
              <TextBlock Grid.Row="0" Grid.Column="8" Text="B" VerticalAlignment="Center" FontWeight="Bold" Visibility="{Binding AxisBVisibility}"/>
              <TextBlock Grid.Row="0" Grid.Column="9" Text="{Binding WorkB}" Style="{StaticResource DroValue}" Visibility="{Binding AxisBVisibility}"/>
              <TextBlock Grid.Row="0" Grid.Column="10" Text="C" VerticalAlignment="Center" FontWeight="Bold" Visibility="{Binding AxisCVisibility}"/>
              <TextBlock Grid.Row="0" Grid.Column="11" Text="{Binding WorkC}" Style="{StaticResource DroValue}" Visibility="{Binding AxisCVisibility}"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="mX" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MachineX}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
              <TextBlock Grid.Row="1" Grid.Column="2" Text="mY" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding MachineY}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
              <TextBlock Grid.Row="1" Grid.Column="4" Text="mZ" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
              <TextBlock Grid.Row="1" Grid.Column="5" Text="{Binding MachineZ}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
              <TextBlock Grid.Row="1" Grid.Column="6" Text="mA" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Visibility="{Binding AxisAVisibility}"/>
              <TextBlock Grid.Row="1" Grid.Column="7" Text="{Binding MachineA}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas" Visibility="{Binding AxisAVisibility}"/>
              <TextBlock Grid.Row="1" Grid.Column="8" Text="mB" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Visibility="{Binding AxisBVisibility}"/>
              <TextBlock Grid.Row="1" Grid.Column="9" Text="{Binding MachineB}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas" Visibility="{Binding AxisBVisibility}"/>
              <TextBlock Grid.Row="1" Grid.Column="10" Text="mC" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Visibility="{Binding AxisCVisibility}"/>
              <TextBlock Grid.Row="1" Grid.Column="11" Text="{Binding MachineC}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas" Visibility="{Binding AxisCVisibility}"/>
            </Grid>
          </DockPanel>
        </Border>

        <!-- Workspace -->
        <Border Style="{StaticResource PanelBorder}" Grid.Row="1" Padding="2">
          <Grid Background="{StaticResource BgDeepBrush}"
                MouseWheel="PreviewHost_MouseWheel"
                MouseLeftButtonDown="PreviewHost_MouseLeftButtonDown"
                MouseLeftButtonUp="PreviewHost_MouseLeftButtonUp"
                MouseMove="PreviewHost_MouseMove">
            <Image Source="{Binding PlaceholderImage}" Stretch="Uniform"
                   Visibility="{Binding ShowPlaceholder, Converter={StaticResource BoolToVis}}"/>
            <Viewbox Stretch="Uniform" Margin="12">
              <Canvas Width="{Binding PreviewWidth}" Height="{Binding PreviewHeight}"
                      Background="Transparent"
                      MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                      MouseRightButtonDown="PreviewCanvas_MouseRightButtonDown">
                <Canvas.RenderTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleX="{Binding ViewZoom}" ScaleY="{Binding ViewZoom}"/>
                    <TranslateTransform X="{Binding ViewPanX}" Y="{Binding ViewPanY}"/>
                  </TransformGroup>
                </Canvas.RenderTransform>
                <Canvas.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Reload last file" Command="{Binding ReloadLastFileCommand}"/>
                    <MenuItem Header="Paste from clipboard" Command="{Binding PasteFromClipboardCommand}"/>
                    <MenuItem Header="Reset zoom" Command="{Binding ResetZoomCommand}"/>
                    <Separator/>
                    <MenuItem Header="Delete selected path" Command="{Binding PathDeleteSelectedCommand}"/>
                    <MenuItem Header="Duplicate selected path" Command="{Binding PathDuplicateSelectedCommand}"/>
                    <MenuItem Header="Crop to selected" Command="{Binding PathCropSelectedCommand}"/>
                    <MenuItem Header="Reverse selected path" Command="{Binding PathReverseSelectedCommand}"/>
                    <MenuItem Header="Rotate selected 90°" Command="{Binding PathRotateSelectedCommand}"/>
                    <MenuItem Header="Path properties…" Command="{Binding ShowPathPropertiesCommand}"/>
                    <MenuItem Header="Mark first point of selection" Command="{Binding MarkFirstPointOfSelectionCommand}"/>
                    <Separator/>
                    <MenuItem Header="Set marker here" Click="SetMarkerHere_Click"/>
                    <MenuItem Header="G0 to marker" Command="{Binding MarkerMoveG0Command}"/>
                    <MenuItem Header="Zero XY at marker (G10)" Command="{Binding MarkerZeroXyCommand}"/>
                    <MenuItem Header="Offset graphics: marker → 0;0" Command="{Binding OffsetGraphicsMarkerToZeroCommand}"/>
                    <MenuItem Header="Offset graphics: marker → tool" Command="{Binding OffsetGraphicsMarkerToToolCommand}"/>
                    <MenuItem Header="Apply last transform" Command="{Binding ApplyLastTransformCommand}"/>
                    <Separator/>
                    <MenuItem Header="Copy preview to clipboard" Command="{Binding CopyPreviewToClipboardCommand}"/>
                    <MenuItem Header="Set G-Code as background" Command="{Binding SetGCodeAsBackgroundCommand}"/>
                    <MenuItem Header="Clear background" Command="{Binding ClearBackgroundCommand}"/>
                  </ContextMenu>
                </Canvas.ContextMenu>
                <Path Stroke="#FF3A4A58" StrokeThickness="0.6" Data="{Binding RulerGridGeometry}"
                      Visibility="{Binding RulerVisibility}" Opacity="0.85"/>
                <Path Stroke="#FFA8B8C8" StrokeThickness="1.15" Data="{Binding RulerGeometry}"
                      Visibility="{Binding RulerVisibility}"/>
                <ItemsControl ItemsSource="{Binding RulerLabels}" Visibility="{Binding RulerVisibility}"
                              IsHitTestVisible="False">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{Binding X}"/>
                      <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                  </ItemsControl.ItemContainerStyle>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Text}" Foreground="#FFD0DAE4" FontSize="10"
                                 FontFamily="Consolas" FontWeight="SemiBold"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Path Stroke="#FFFF7A7A" StrokeThickness="1.2" StrokeDashArray="4 2" Data="{Binding LimitsGeometry}"
                      Visibility="{Binding LimitsVisibility}"/>
                <Path Stroke="#FF5A6A7A" StrokeThickness="1.0" Data="{Binding BackgroundGeometry}"
                      Visibility="{Binding BackgroundVisibility}" Opacity="0.65"/>
                <Path Stroke="#FF7DDA95" StrokeThickness="1.4" Data="{Binding ToolpathGeometry}"
                      Visibility="{Binding ToolpathVisibility}"/>
                <Path Stroke="#FF6EC4D8" StrokeThickness="1.0" StrokeDashArray="2 2" Data="{Binding RapidGeometry}"
                      Visibility="{Binding RapidVisibility}"/>
                <Path Stroke="#FFFFC857" StrokeThickness="2.4" Data="{Binding SelectionGeometry}"
                      Visibility="{Binding SelectionVisibility}"/>
                <Path Stroke="#FFE0B86A" StrokeThickness="1.5" Data="{Binding ToolTableGeometry}"
                      Visibility="{Binding ToolTableVisibility}"/>
                <TextBlock Text="{Binding InfoHudText}" Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           FontWeight="SemiBold" Canvas.Left="40" Canvas.Top="4" Visibility="{Binding InfoHudVisibility}"/>
                <TextBlock Text="{Binding DimensionText}" Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           Canvas.Left="40" Canvas.Top="20" Visibility="{Binding DimensionVisibility}"/>
                <Ellipse Width="10" Height="10" Fill="#FFFF6B6B" Stroke="#FF1A1F26" StrokeThickness="1"
                         Visibility="{Binding MarkerVisibility}"
                         Canvas.Left="{Binding MarkerCanvasX}" Canvas.Top="{Binding MarkerCanvasY}"
                         Margin="-5,-5,0,0"/>
                <Ellipse Width="8" Height="8" Fill="#FFE6C35C" Stroke="#FF1A1F26" StrokeThickness="1"
                         Visibility="{Binding SimMarkerVisibility}"
                         Canvas.Left="{Binding SimX}" Canvas.Top="{Binding SimY}"
                         Margin="-4,-4,0,0"/>
              </Canvas>
            </Viewbox>
          </Grid>
        </Border>

        <!-- Mode row -->
        <Border Style="{StaticResource PanelBorder}" Grid.Row="2">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <RadioButton Content="Edit figure" IsChecked="{Binding ModeEdit, Mode=TwoWay}" GroupName="mode"/>
              <RadioButton Content="Jog to figure pos." IsChecked="{Binding ModeJogFigure, Mode=TwoWay}" GroupName="mode" Margin="12,0,0,0"/>
              <RadioButton Content="Jog to clicked pos." IsChecked="{Binding ModeJogClick, Mode=TwoWay}" GroupName="mode" Margin="12,0,0,0"/>
              <CheckBox Content="Add imported graphic to 2D-view" IsChecked="{Binding AddImportedToView, Mode=TwoWay}" Margin="16,0,0,0"/>
            </StackPanel>
            <DockPanel Margin="0,6,0,0">
              <Button DockPanel.Dock="Right" Content="Load" Command="{Binding LoadFromUrlCommand}" MinWidth="64" Margin="6,0,0,0"/>
              <TextBox ToolTip="Paste file path or http(s) URL of SVG / DXF"
                       Text="{Binding UrlPaste, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- RIGHT -->
      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <Border Style="{StaticResource PanelBorder}">
            <TabControl>
              <TabItem Header="Laser">
                <StackPanel Margin="4">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="Power" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding LaserPower}"/>
                    <TextBlock Grid.Row="1" Text="Speed" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LaserSpeed}"/>
                    <TextBlock Grid.Row="2" Text="Passes" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LaserPasses}"/>
                  </Grid>
                  <CheckBox Content="Air assist" IsChecked="{Binding AirAssist}" Margin="0,6,0,0"/>
                  <UniformGrid Columns="2" Margin="0,6,0,0">
                    <Button Content="Laser ON" Command="{Binding LaserOnCommand}"/>
                    <Button Content="Laser OFF" Command="{Binding LaserOffCommand}" Style="{StaticResource GhostButton}"/>
                  </UniformGrid>
                  <Button Content="Apply defaults" Command="{Binding ApplyLaserDefaultsCommand}" Style="{StaticResource GhostButton}"/>
                </StackPanel>
              </TabItem>
              <TabItem Header="Plotter">
                <StackPanel Margin="4">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="Z Up" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding PlotterZUp}"/>
                    <TextBlock Grid.Row="1" Text="Z Down" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PlotterZDown}"/>
                    <TextBlock Grid.Row="2" Text="Speed" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PlotterSpeed}"/>
                  </Grid>
                  <UniformGrid Columns="4" Margin="0,6,0,0">
                    <Button Content="Up" Command="{Binding PenUpCommand}" Style="{StaticResource GhostButton}"/>
                    <Button Content="Down" Command="{Binding PenDownCommand}" Style="{StaticResource GhostButton}"/>
                    <Button Content="Zero" Command="{Binding PenZeroCommand}" Style="{StaticResource GhostButton}"/>
                    <Button Content="Dot" Command="{Binding PenDotCommand}" Style="{StaticResource GhostButton}"/>
                  </UniformGrid>
                  <Button Content="Apply defaults" Command="{Binding ApplyPlotterDefaultsCommand}" Margin="0,6,0,0" Style="{StaticResource GhostButton}"/>
                </StackPanel>
              </TabItem>
              <TabItem Header="Tools">
                <StackPanel Margin="4">
                  <ListBox ItemsSource="{Binding Tools}" SelectedItem="{Binding SelectedTool}" Height="100"
                           DisplayMemberPath="Name"/>
                  <UniformGrid Columns="2" Margin="0,4,0,0">
                    <Button Content="Load CSV" Command="{Binding LoadToolListCommand}" Style="{StaticResource GhostButton}"/>
                    <Button Content="Save CSV" Command="{Binding SaveToolListCommand}" Style="{StaticResource GhostButton}"/>
                    <Button Content="By color" Command="{Binding GroupToolsByColorCommand}" Style="{StaticResource GhostButton}"/>
                    <Button Content="Apply T" Command="{Binding ApplySelectedToolCommand}" Style="{StaticResource GhostButton}"/>
                  </UniformGrid>
                </StackPanel>
              </TabItem>
              <TabItem Header="Router">
                <StackPanel Margin="4">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="F XY" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding RouterSpeedXy}"/>
                    <TextBlock Grid.Row="1" Text="F Z" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RouterSpeedZ}"/>
                    <TextBlock Grid.Row="2" Text="Depth" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RouterDepth}"/>
                  </Grid>
                  <Button Content="Apply defaults" Command="{Binding ApplyRouterDefaultsCommand}" Margin="0,6,0,0" Style="{StaticResource GhostButton}"/>
                </StackPanel>
              </TabItem>
            </TabControl>
          </Border>

          <!-- Move to graphic -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Move to graphic" Style="{StaticResource PanelHeader}"/>
              <UniformGrid Columns="3">
                <Button Content="TL" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="TL" Style="{StaticResource GhostButton}"/>
                <Button Content="TC" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="TC" Style="{StaticResource GhostButton}"/>
                <Button Content="TR" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="TR" Style="{StaticResource GhostButton}"/>
                <Button Content="ML" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="ML" Style="{StaticResource GhostButton}"/>
                <Button Content="C" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="C" Style="{StaticResource GhostButton}"/>
                <Button Content="MR" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="MR" Style="{StaticResource GhostButton}"/>
                <Button Content="BL" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="BL" Style="{StaticResource GhostButton}"/>
                <Button Content="BC" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="BC" Style="{StaticResource GhostButton}"/>
                <Button Content="BR" Command="{Binding MoveToGraphicCornerCommand}" CommandParameter="BR" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <Button Content="Framing" Command="{Binding FrameGraphicCommand}" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

          <!-- Move to zero -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Move to zero" Style="{StaticResource PanelHeader}"/>
              <CheckBox Content="Use G0 (else jog)" IsChecked="{Binding MoveUseG0}" Margin="0,0,0,4"/>
              <UniformGrid Columns="3">
                <Button Content="X=0" Command="{Binding MoveAxisToZeroCommand}" CommandParameter="X" Style="{StaticResource GhostButton}"/>
                <Button Content="Y=0" Command="{Binding MoveAxisToZeroCommand}" CommandParameter="Y" Style="{StaticResource GhostButton}"/>
                <Button Content="Z=0" Command="{Binding MoveAxisToZeroCommand}" CommandParameter="Z" Style="{StaticResource GhostButton}"/>
                <Button Content="XY=0" Command="{Binding MoveAxisToZeroCommand}" CommandParameter="XY" Style="{StaticResource GhostButton}"/>
                <Button Content="STOP" Command="{Binding JogCancelCommand}" Style="{StaticResource DangerButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Jog -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Move / Jog" Style="{StaticResource PanelHeader}"/>
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="Step" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding JogStep}"/>
                <TextBlock Grid.Row="1" Text="Feed" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding JogFeed}"/>
              </Grid>
              <UniformGrid Columns="3">
                <Button Content="↖" Command="{Binding JogCommand}" CommandParameter="X-Y+" Style="{StaticResource GhostButton}"/>
                <Button Content="Y+" Command="{Binding JogCommand}" CommandParameter="Y+"/>
                <Button Content="↗" Command="{Binding JogCommand}" CommandParameter="X+Y+" Style="{StaticResource GhostButton}"/>
                <Button Content="X-" Command="{Binding JogCommand}" CommandParameter="X-"/>
                <Button Content="Cancel" Command="{Binding JogCancelCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="X+" Command="{Binding JogCommand}" CommandParameter="X+"/>
                <Button Content="↙" Command="{Binding JogCommand}" CommandParameter="X-Y-" Style="{StaticResource GhostButton}"/>
                <Button Content="Y-" Command="{Binding JogCommand}" CommandParameter="Y-"/>
                <Button Content="↘" Command="{Binding JogCommand}" CommandParameter="X+Y-" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <UniformGrid Columns="2" Margin="0,6,0,0">
                <Button Content="Z+" Command="{Binding JogCommand}" CommandParameter="Z+"/>
                <Button Content="Z-" Command="{Binding JogCommand}" CommandParameter="Z-"/>
              </UniformGrid>
              <UniformGrid Columns="2" Margin="0,6,0,0" Visibility="{Binding AxisAVisibility}">
                <Button Content="A+" Command="{Binding JogCommand}" CommandParameter="A+"/>
                <Button Content="A-" Command="{Binding JogCommand}" CommandParameter="A-"/>
              </UniformGrid>
              <UniformGrid Columns="2" Margin="0,4,0,0" Visibility="{Binding AxisBVisibility}">
                <Button Content="B+" Command="{Binding JogCommand}" CommandParameter="B+"/>
                <Button Content="B-" Command="{Binding JogCommand}" CommandParameter="B-"/>
              </UniformGrid>
              <UniformGrid Columns="2" Margin="0,4,0,0" Visibility="{Binding AxisCVisibility}">
                <Button Content="C+" Command="{Binding JogCommand}" CommandParameter="C+"/>
                <Button Content="C-" Command="{Binding JogCommand}" CommandParameter="C-"/>
              </UniformGrid>
              <UniformGrid Columns="3" Margin="0,6,0,0">
                <Button Content="Zero X" Command="{Binding ZeroXCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Zero Y" Command="{Binding ZeroYCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Zero Z" Command="{Binding ZeroZCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <UniformGrid Columns="3" Margin="0,4,0,0">
                <Button Content="Zero A" Command="{Binding ZeroACommand}" Style="{StaticResource GhostButton}" Visibility="{Binding AxisAVisibility}"/>
                <Button Content="Zero B" Command="{Binding ZeroBCommand}" Style="{StaticResource GhostButton}" Visibility="{Binding AxisBVisibility}"/>
                <Button Content="Zero C" Command="{Binding ZeroCCommand}" Style="{StaticResource GhostButton}" Visibility="{Binding AxisCVisibility}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Quick COM -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="COM CNC" Style="{StaticResource PanelHeader}"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaud}" Margin="4,0"/>
                <Button Grid.Column="2" Content="{Binding IsConnected, Converter={StaticResource ConnLabel}}" Command="{Binding ConnectToggleCommand}" MinWidth="64"/>
              </Grid>
              <Button Content="Scan ports" Command="{Binding RefreshPortsCommand}" Style="{StaticResource GhostButton}" Margin="0,4,0,0"/>
              <Button Content="Open full COM window…" Click="OpenSerial_Click" Style="{StaticResource GhostButton}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
