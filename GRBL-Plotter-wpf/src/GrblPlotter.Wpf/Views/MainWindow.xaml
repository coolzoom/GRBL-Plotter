<Window x:Class="GrblPlotter.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GrblPlotter.Wpf.ViewModels"
        Title="{Binding WindowTitle}"
        Height="820" Width="1280"
        MinHeight="640" MinWidth="1024"
        Icon="/Assets/Icon.ico"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="Open…" Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
        <MenuItem Header="Save…" Command="{Binding SaveFileCommand}" InputGestureText="Ctrl+S"/>
        <MenuItem Header="Clear workspace" Command="{Binding ClearWorkspaceCommand}"/>
        <MenuItem Header="Undo" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
        <Separator/>
        <MenuItem Header="Setup…" Click="OpenSetup_Click"/>
        <MenuItem Header="About…" Click="OpenAbout_Click"/>
        <Separator/>
        <MenuItem Header="Exit" Click="Exit_Click"/>
      </MenuItem>
      <MenuItem Header="_G-Code Creation">
        <MenuItem Header="Import any (SVG/DXF/HPGL/Gerber/Image/CSV)…" Command="{Binding OpenFileCommand}"/>
        <Separator/>
        <MenuItem Header="Text…" Click="OpenText_Click"/>
        <MenuItem Header="Shape…" Click="OpenShape_Click"/>
        <MenuItem Header="Image engraving…" Click="OpenImage_Click"/>
        <MenuItem Header="Barcode…" Click="OpenBarcode_Click"/>
        <MenuItem Header="Wire cutter…" Click="OpenWire_Click"/>
      </MenuItem>
      <MenuItem Header="_G-Code Transform">
        <MenuItem Header="Mirror X" Command="{Binding TransformMirrorXCommand}"/>
        <MenuItem Header="Mirror Y" Command="{Binding TransformMirrorYCommand}"/>
        <MenuItem Header="Rotate" Command="{Binding ApplyRotateTransformCommand}"/>
        <MenuItem Header="Scale" Command="{Binding ApplyScaleTransformCommand}"/>
        <MenuItem Header="Translate" Command="{Binding ApplyTranslateTransformCommand}"/>
        <Separator/>
        <MenuItem Header="Origin → Center" Command="{Binding TransformOriginCenterCommand}"/>
        <MenuItem Header="Origin → Min XY" Command="{Binding TransformOriginMinCommand}"/>
        <MenuItem Header="Reverse paths" Command="{Binding TransformReverseCommand}"/>
        <Separator/>
        <MenuItem Header="Reparse editor" Command="{Binding ApplyEditorCommand}"/>
      </MenuItem>
      <MenuItem Header="_Workpiece">
        <MenuItem Header="Home ($H)" Command="{Binding HomeMachineCommand}"/>
        <MenuItem Header="Zero XYZ" Command="{Binding ZeroXyzCommand}"/>
        <MenuItem Header="Zero XY" Command="{Binding ZeroXyCommand}"/>
        <Separator/>
        <MenuItem Header="Coordinate systems…" Click="OpenCoord_Click"/>
        <MenuItem Header="G54" Command="{Binding SelectCoordCommand}" CommandParameter="G54"/>
        <MenuItem Header="G55" Command="{Binding SelectCoordCommand}" CommandParameter="G55"/>
        <MenuItem Header="G56" Command="{Binding SelectCoordCommand}" CommandParameter="G56"/>
        <Separator/>
        <MenuItem Header="Probing…" Click="OpenProbing_Click"/>
        <MenuItem Header="Height map…" Click="OpenHeightMap_Click"/>
      </MenuItem>
      <MenuItem Header="_Machine">
        <MenuItem Header="COM CNC…" Click="OpenSerial_Click"/>
        <MenuItem Header="2nd Serial / DIY…" Click="OpenSecondSerial_Click"/>
        <MenuItem Header="Refresh ports" Command="{Binding RefreshPortsCommand}"/>
        <Separator/>
        <MenuItem Header="Camera…" Click="OpenCamera_Click"/>
        <MenuItem Header="Projector…" Click="OpenProjector_Click"/>
        <MenuItem Header="Process automation…" Click="OpenAutomation_Click"/>
        <Separator/>
        <MenuItem Header="Soft RESET" Command="{Binding SoftResetCommand}"/>
        <MenuItem Header="Kill Alarm $X" Command="{Binding KillAlarmCommand}"/>
        <MenuItem Header="Feed Hold" Command="{Binding FeedHoldCommand}"/>
        <MenuItem Header="Cycle Start" Command="{Binding CycleStartCommand}"/>
      </MenuItem>
      <MenuItem Header="_Simulation">
        <MenuItem Header="Start" Command="{Binding SimStartCommand}"/>
        <MenuItem Header="Pause" Command="{Binding SimPauseCommand}"/>
        <MenuItem Header="Resume" Command="{Binding SimResumeCommand}"/>
        <MenuItem Header="Stop" Command="{Binding SimStopCommand}"/>
      </MenuItem>
    </Menu>

    <StatusBar DockPanel.Dock="Bottom">
      <StatusBarItem>
        <Border Style="{StaticResource StatusBanner}" MinWidth="220">
          <TextBlock Text="{Binding ConnectionText}"/>
        </Border>
      </StatusBarItem>
      <StatusBarItem>
        <Border Style="{StaticResource StatusBanner}" MinWidth="280">
          <TextBlock Text="{Binding StatusBanner}"/>
        </Border>
      </StatusBarItem>
      <StatusBarItem HorizontalAlignment="Right">
        <TextBlock Text="{Binding MachineStateText, StringFormat=State: {0}}" Foreground="{StaticResource TextMutedBrush}"/>
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="240"/>
        <ColumnDefinition Width="*" MinWidth="360"/>
        <ColumnDefinition Width="300" MinWidth="260"/>
      </Grid.ColumnDefinitions>

      <!-- LEFT -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <!-- Streaming -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="G-Code Streaming" Style="{StaticResource PanelHeader}"/>
              <TextBlock Text="{Binding StreamInfo}" Foreground="{StaticResource TextMutedBrush}"/>
              <ProgressBar Height="10" Margin="0,4" Minimum="0" Maximum="100" Value="{Binding StreamProgress}"/>
              <UniformGrid Columns="3">
                <Button Content="Start" Command="{Binding StreamStartCommand}" IsEnabled="{Binding IsConnected}"/>
                <Button Content="Check" Command="{Binding StreamCheckCommand}" Style="{StaticResource GhostButton}" IsEnabled="{Binding IsConnected}"/>
                <Button Content="Stop" Command="{Binding StreamStopCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <UniformGrid Columns="2">
                <Button Content="Pause / Hold" Command="{Binding StreamPauseCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Resume" Command="{Binding StreamResumeCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="Simulation" Margin="0,8,0,2" Foreground="{StaticResource TextMutedBrush}"/>
              <UniformGrid Columns="4">
                <Button Content="Sim" Command="{Binding SimStartCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="❚❚" Command="{Binding SimPauseCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="▶" Command="{Binding SimResumeCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="■" Command="{Binding SimStopCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="{Binding FileLabel}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
              <TextBlock Text="{Binding DimensionText, StringFormat=Dim {0}}" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </Border>

          <!-- Flow -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Flow Control" Style="{StaticResource PanelHeader}"/>
              <UniformGrid Columns="2">
                <Button Content="Feed Hold" Command="{Binding FeedHoldCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Resume" Command="{Binding CycleStartCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Kill Alarm" Command="{Binding KillAlarmCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Door" Command="{Binding DoorCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <Button Content="RESET" Command="{Binding SoftResetCommand}" Style="{StaticResource DangerButton}" Height="36" FontWeight="Bold"/>
            </StackPanel>
          </Border>

          <!-- Overrides -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Overrides" Style="{StaticResource PanelHeader}"/>
              <TextBlock Text="{Binding OvFeed, StringFormat=Feed {0}%}" />
              <UniformGrid Columns="3">
                <Button Content="−" Command="{Binding OvFeedMinusCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="100%" Command="{Binding OvFeedResetCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="+" Command="{Binding OvFeedPlusCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="{Binding OvRapid, StringFormat=Rapid {0}%}" Margin="0,6,0,0"/>
              <UniformGrid Columns="3">
                <Button Content="25%" Command="{Binding OvRapid25Command}" Style="{StaticResource GhostButton}"/>
                <Button Content="50%" Command="{Binding OvRapid50Command}" Style="{StaticResource GhostButton}"/>
                <Button Content="100%" Command="{Binding OvRapid100Command}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
              <TextBlock Text="{Binding OvSpindle, StringFormat=Spindle {0}%}" Margin="0,6,0,0"/>
              <UniformGrid Columns="3">
                <Button Content="−" Command="{Binding OvSpindleMinusCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="100%" Command="{Binding OvSpindleResetCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="+" Command="{Binding OvSpindlePlusCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Origin -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Set G-Code Origin XY" Style="{StaticResource PanelHeader}"/>
              <UniformGrid Columns="3">
                <Button Content="TL" Command="{Binding SetOriginCornerCommand}" CommandParameter="TopLeft" Style="{StaticResource GhostButton}"/>
                <Button Content="TC" Command="{Binding SetOriginCornerCommand}" CommandParameter="TopCenter" Style="{StaticResource GhostButton}"/>
                <Button Content="TR" Command="{Binding SetOriginCornerCommand}" CommandParameter="TopRight" Style="{StaticResource GhostButton}"/>
                <Button Content="ML" Command="{Binding SetOriginCornerCommand}" CommandParameter="MidLeft" Style="{StaticResource GhostButton}"/>
                <Button Content="C" Command="{Binding SetOriginCornerCommand}" CommandParameter="Center" Style="{StaticResource GhostButton}"/>
                <Button Content="MR" Command="{Binding SetOriginCornerCommand}" CommandParameter="MidRight" Style="{StaticResource GhostButton}"/>
                <Button Content="BL" Command="{Binding SetOriginCornerCommand}" CommandParameter="BotLeft" Style="{StaticResource GhostButton}"/>
                <Button Content="BC" Command="{Binding SetOriginCornerCommand}" CommandParameter="BotCenter" Style="{StaticResource GhostButton}"/>
                <Button Content="BR" Command="{Binding SetOriginCornerCommand}" CommandParameter="BotRight" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Transform -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Transform" Style="{StaticResource PanelHeader}"/>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="Scale" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding TransformScale}"/>
                <TextBlock Grid.Row="1" Text="Rot°" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TransformRotate}"/>
                <TextBlock Grid.Row="2" Text="dX" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TransformDx}"/>
                <TextBlock Grid.Row="3" Text="dY" VerticalAlignment="Center"/><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TransformDy}"/>
              </Grid>
              <UniformGrid Columns="3" Margin="0,4,0,0">
                <Button Content="Scale" Command="{Binding ApplyScaleTransformCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Rotate" Command="{Binding ApplyRotateTransformCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Move" Command="{Binding ApplyTranslateTransformCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Mir X" Command="{Binding TransformMirrorXCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Mir Y" Command="{Binding TransformMirrorYCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Rev" Command="{Binding TransformReverseCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Custom buttons -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Custom / Scripts" Style="{StaticResource PanelHeader}"/>
              <ItemsControl ItemsSource="{Binding CustomButtons}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="4"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding Label}" Command="{Binding DataContext.RunCustomCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Margin="1" FontSize="11"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Editor -->
          <Border Style="{StaticResource PanelBorder}" MinHeight="180">
            <DockPanel>
              <TextBlock DockPanel.Dock="Top" Text="G-Code" Style="{StaticResource PanelHeader}"/>
              <Button DockPanel.Dock="Bottom" Content="Apply / Reparse" Command="{Binding ApplyEditorCommand}" Margin="0,4,0,0"/>
              <TextBox Text="{Binding GcodeText, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                       FontFamily="Consolas" FontSize="11"
                       TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"/>
            </DockPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- CENTER -->
      <Grid Grid.Column="1" Margin="4,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DRO -->
        <Border Style="{StaticResource PanelBorder}" Grid.Row="0">
          <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <Button Content="Home" Command="{Binding HomeMachineCommand}" Width="72"/>
              <Button Content="Zero XY" Command="{Binding ZeroXyCommand}" Style="{StaticResource GhostButton}"/>
              <Button Content="Zero XYZ" Command="{Binding ZeroXyzCommand}" Style="{StaticResource GhostButton}"/>
            </StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/>
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="X" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WorkX}" Style="{StaticResource DroValue}"/>
              <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding WorkY}" Style="{StaticResource DroValue}"/>
              <TextBlock Grid.Row="0" Grid.Column="4" Text="Z" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding WorkZ}" Style="{StaticResource DroValue}"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="mX" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MachineX}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
              <TextBlock Grid.Row="1" Grid.Column="2" Text="mY" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding MachineY}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
              <TextBlock Grid.Row="1" Grid.Column="4" Text="mZ" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
              <TextBlock Grid.Row="1" Grid.Column="5" Text="{Binding MachineZ}" Foreground="{StaticResource TextMutedBrush}" FontFamily="Consolas"/>
            </Grid>
          </DockPanel>
        </Border>

        <!-- Workspace -->
        <Border Style="{StaticResource PanelBorder}" Grid.Row="1" Padding="2">
          <Grid Background="{StaticResource BgDeepBrush}">
            <Image Source="{Binding PlaceholderImage}" Stretch="Uniform"
                   Visibility="{Binding ShowPlaceholder, Converter={StaticResource BoolToVis}}"/>
            <Viewbox Stretch="Uniform" Margin="12">
              <Canvas Width="400" Height="300">
                <Path Stroke="#FF6FBF8A" StrokeThickness="1.2" Data="{Binding ToolpathGeometry}"/>
                <Path Stroke="#FF4A90A4" StrokeThickness="0.8" StrokeDashArray="2 2" Data="{Binding RapidGeometry}"/>
                <Ellipse Width="8" Height="8" Fill="#FFE6C35C" Stroke="#FF1A1F26" StrokeThickness="1"
                         Visibility="{Binding SimMarkerVisibility}"
                         Canvas.Left="{Binding SimX}" Canvas.Top="{Binding SimY}"
                         Margin="-4,-4,0,0"/>
              </Canvas>
            </Viewbox>
          </Grid>
        </Border>

        <!-- Mode row -->
        <Border Style="{StaticResource PanelBorder}" Grid.Row="2">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <RadioButton Content="Edit figure" IsChecked="True" GroupName="mode"/>
              <RadioButton Content="Jog to figure pos." GroupName="mode" Margin="12,0,0,0"/>
              <RadioButton Content="Jog to clicked pos." GroupName="mode" Margin="12,0,0,0"/>
              <CheckBox Content="Add imported graphic to 2D-view" Margin="16,0,0,0"/>
            </StackPanel>
            <TextBox Margin="0,6,0,0" Tag="url" ToolTip="Paste URL of SVG / DXF file here"
                     Text="Paste URL of SVG / DXF file here"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- RIGHT -->
      <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <Border Style="{StaticResource PanelBorder}">
            <TabControl>
              <TabItem Header="Laser">
                <StackPanel Margin="4">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="Power" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding LaserPower}"/>
                    <TextBlock Grid.Row="1" Text="Speed" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding LaserSpeed}"/>
                    <TextBlock Grid.Row="2" Text="Passes" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LaserPasses}"/>
                  </Grid>
                  <CheckBox Content="Air assist" IsChecked="{Binding AirAssist}" Margin="0,6,0,0"/>
                  <UniformGrid Columns="2" Margin="0,6,0,0">
                    <Button Content="Laser ON" Command="{Binding LaserOnCommand}"/>
                    <Button Content="Laser OFF" Command="{Binding LaserOffCommand}" Style="{StaticResource GhostButton}"/>
                  </UniformGrid>
                  <Button Content="Apply defaults" Command="{Binding ApplyLaserDefaultsCommand}" Style="{StaticResource GhostButton}"/>
                </StackPanel>
              </TabItem>
              <TabItem Header="Plotter">
                <StackPanel Margin="4">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="Z Up" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding PlotterZUp}"/>
                    <TextBlock Grid.Row="1" Text="Z Down" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PlotterZDown}"/>
                    <TextBlock Grid.Row="2" Text="Speed" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PlotterSpeed}"/>
                  </Grid>
                  <Button Content="Apply defaults" Command="{Binding ApplyPlotterDefaultsCommand}" Margin="0,6,0,0" Style="{StaticResource GhostButton}"/>
                </StackPanel>
              </TabItem>
              <TabItem Header="Router">
                <StackPanel Margin="4">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <TextBlock Text="F XY" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding RouterSpeedXy}"/>
                    <TextBlock Grid.Row="1" Text="F Z" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RouterSpeedZ}"/>
                    <TextBlock Grid.Row="2" Text="Depth" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RouterDepth}"/>
                  </Grid>
                  <Button Content="Apply defaults" Command="{Binding ApplyRouterDefaultsCommand}" Margin="0,6,0,0" Style="{StaticResource GhostButton}"/>
                </StackPanel>
              </TabItem>
            </TabControl>
          </Border>

          <!-- Jog -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="Move / Jog" Style="{StaticResource PanelHeader}"/>
              <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Text="Step" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding JogStep}"/>
                <TextBlock Grid.Row="1" Text="Feed" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding JogFeed}"/>
              </Grid>
              <UniformGrid Columns="3">
                <Button Content="↖" Command="{Binding JogCommand}" CommandParameter="X-" Style="{StaticResource GhostButton}" Tag="diag"/>
                <Button Content="Y+" Command="{Binding JogCommand}" CommandParameter="Y+"/>
                <Button Content="↗" Command="{Binding JogCommand}" CommandParameter="X+" Style="{StaticResource GhostButton}"/>
                <Button Content="X-" Command="{Binding JogCommand}" CommandParameter="X-"/>
                <Button Content="Cancel" Command="{Binding JogCancelCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="X+" Command="{Binding JogCommand}" CommandParameter="X+"/>
                <Button Content="↙" Style="{StaticResource GhostButton}" IsEnabled="False"/>
                <Button Content="Y-" Command="{Binding JogCommand}" CommandParameter="Y-"/>
                <Button Content="↘" Style="{StaticResource GhostButton}" IsEnabled="False"/>
              </UniformGrid>
              <UniformGrid Columns="2" Margin="0,6,0,0">
                <Button Content="Z+" Command="{Binding JogCommand}" CommandParameter="Z+"/>
                <Button Content="Z-" Command="{Binding JogCommand}" CommandParameter="Z-"/>
              </UniformGrid>
              <UniformGrid Columns="3" Margin="0,6,0,0">
                <Button Content="Zero X" Command="{Binding ZeroXCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Zero Y" Command="{Binding ZeroYCommand}" Style="{StaticResource GhostButton}"/>
                <Button Content="Zero Z" Command="{Binding ZeroZCommand}" Style="{StaticResource GhostButton}"/>
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Quick COM -->
          <Border Style="{StaticResource PanelBorder}">
            <StackPanel>
              <TextBlock Text="COM CNC" Style="{StaticResource PanelHeader}"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox ItemsSource="{Binding Ports}" SelectedItem="{Binding SelectedPort}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaud}" Margin="4,0"/>
                <Button Grid.Column="2" Content="{Binding IsConnected, Converter={StaticResource ConnLabel}}" Command="{Binding ConnectToggleCommand}" MinWidth="64"/>
              </Grid>
              <Button Content="Scan ports" Command="{Binding RefreshPortsCommand}" Style="{StaticResource GhostButton}" Margin="0,4,0,0"/>
              <Button Content="Open full COM window…" Click="OpenSerial_Click" Style="{StaticResource GhostButton}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
